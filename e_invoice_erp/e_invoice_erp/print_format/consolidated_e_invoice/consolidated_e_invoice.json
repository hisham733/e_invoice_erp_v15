 "doctype": "Print Format",
 "font": "Default",
 "html": "<!DOCTYPE html>\n<html>\n<head>\n<meta charset=\"utf-8\">\n<link href=\"https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;600&display=swap\" rel=\"stylesheet\">\n<style>\n/* SCOPED CSS - Print-safe & B&W Optimized */\n.myeinv-format {\n    --ink:       #1a202c; /* Charcoal instead of pure black for better B&W contrast */\n    --ink-muted: #4a5568;\n    --accent:    #8b6d31; /* Deeper gold - shows as a clear medium gray in B&W */\n    --accent-lt: #f7fafc; /* Very light gray background for headers */\n    --rule:      #cbd5e0; /* Slightly darker lines for B&W visibility */\n    --surface:   #f8fafc;\n    --white:     #ffffff;\n\n    font-family: 'DM Sans', sans-serif;\n    font-size: 11.5px;\n    color: var(--ink);\n    line-height: 1.5;\n    background: var(--white);\n    max-width: 100%;\n    margin: 0 auto;\n    padding: 10px;\n}\n\n@media print {\n    @page { size: A4 portrait; margin: 12mm 15mm; }\n    .myeinv-format { padding: 0; }\n    /* Ensures background colors appear in print */\n    body { -webkit-print-color-adjust: exact; print-color-adjust: exact; }\n}\n\n/* \u2500\u2500 TOP HEADER BLOCK \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.myeinv-format .top-band {\n    background: #746135 !important; /* Charcoal Gray */\n    color: #ffffff !important;\n    display: flex;\n    justify-content: space-between;\n    align-items: stretch;\n    border-radius: 4px 4px 0 0;\n    overflow: hidden;\n}\n\n.myeinv-format .top-band-left { padding: 24px; flex: 1; }\n.myeinv-format .doc-label { font-family: 'JetBrains Mono'; font-size: 9px; color: #d4af37; letter-spacing: 0.2em; text-transform: uppercase; font-weight: 700; }\n.myeinv-format h1 { font-family: 'DM Serif Display'; font-size: 26px; font-weight: 400; color: #2d1818 !important; margin: 8px 0 !important; }\n.myeinv-format .company-addr { font-size: 10px; color: #2d1818; line-height: 1.6; }\n\n.myeinv-format .top-band-right { \n    background: #a88a4d !important; /* Bronze/Gold */\n    padding: 20px 24px; \n    display: flex; \n    align-items: center; \n    gap: 20px; \n}\n.myeinv-format .inv-no { font-family: 'DM Serif Display'; font-size: 18px; color: #1a202c !important; font-weight: 700; }\n.myeinv-format .inv-meta { font-size: 11px; color: #1a202c; font-weight: 600; text-align: right; margin-top: 4px; }\n\n.myeinv-format .qr-wrap img { width: 75px; height: 75px; background: #fff; padding: 4px; border: 1px solid #1a202c; border-radius: 4px; }\n\n/* \u2500\u2500 UUID STRIP \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.myeinv-format .uuid-strip { \n    background: #2d3748 !important; \n    padding: 8px 24px; \n    border-radius: 0 0 4px 4px; \n    margin-bottom: 25px; \n    border-top: 1px solid #4a5568;\n}\n.myeinv-format .uuid-label { color: #d4af37; font-family: 'JetBrains Mono'; font-size: 9px; font-weight: 700; }\n.myeinv-format .uuid-value { color: #cbd5e0; font-family: 'JetBrains Mono'; font-size: 9px; }\n\n/* \u2500\u2500 PARTY INFO \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.myeinv-format .parties { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 25px; }\n.myeinv-format .party-card { background: #fff; border: 1px solid #cbd5e0; border-radius: 4px; padding: 18px; border-left: 5px solid #1a202c; }\n.myeinv-format .card-label { font-family: 'JetBrains Mono'; font-size: 8.5px; color: #8b6d31; text-transform: uppercase; font-weight: 700; margin-bottom: 6px; }\n.myeinv-format .card-name { font-size: 14px; font-weight: 700; margin-bottom: 5px; color: #000; }\n\n/* \u2500\u2500 TABLE STYLING \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.myeinv-format .section-heading { font-family: 'JetBrains Mono'; font-size: 9px; color: #1a202c; font-weight: 700; margin-bottom: 10px; text-transform: uppercase; }\n\n.myeinv-format table.inv-table { width: 100%; border-collapse: collapse; margin-bottom: 25px; border: 1px solid #a0aec0; }\n.myeinv-format table.inv-table thead th { \n    background: #2d3748 !important; /* Dark Gray for B&W readability */\n    color: #ffffff !important; \n    padding: 12px 10px; \n    text-align: left; \n    font-size: 10px; \n    text-transform: uppercase; \n    font-weight: 700;\n}\n.myeinv-format table.inv-table tbody td { \n    padding: 12px 10px; \n    border-bottom: 1px solid #e2e8f0; \n    vertical-align: top;\n    color: #000;\n}\n\n.myeinv-format .num { text-align: left !important; font-family: 'JetBrains Mono'; font-size: 10.5px; }\n.myeinv-format .item-name { font-weight: 700; font-size: 11.5px; margin-bottom: 3px; }\n.myeinv-format .item-ref { font-size: 10px; color: #4a5568; }\n\n.myeinv-format .badge { background: #edf2f7; border: 1px solid #cbd5e0; padding: 2px 6px; border-radius: 3px; font-size: 9px; font-weight: 700; color: #1a202c; }\n\n/* \u2500\u2500 TOTALS FOOTER \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.myeinv-format table.inv-table tfoot td { background: #2d3748 !important; color: #ffffff !important; padding: 10px 12px; font-size: 10.5px; }\n.myeinv-format table.inv-table tfoot .num { color: #ffffff !important; font-weight: 700; text-align: right !important; }\n\n/* \u2500\u2500 GRAND TOTAL \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500 */\n.myeinv-format .total-container { display: flex; justify-content: flex-end; margin-top: 10px; }\n.myeinv-format .grand-total-box { \n    background: #1a202c !important; \n    color: #ffffff !important; \n    padding: 20px 30px; \n    border-radius: 4px; \n    text-align: right; \n    min-width: 260px; \n}\n.myeinv-format .gt-value { font-family: 'DM Serif Display'; font-size: 30px; color: #ffffff !important; line-height: 1; margin: 5px 0; }\n</style>\n</head>\n<body>\n\n<div class=\"myeinv-format\">\n    <!-- HEADER -->\n    <div class=\"top-band\">\n        <div class=\"top-band-left\">\n            <div class=\"doc-label\">Consolidated E-Invoice</div>\n            <h1>{{ doc.company or \"Company Name\" }}</h1>\n            <div class=\"company-addr\">\n                {{ doc.supplier_location or \"\" }}\n                {{ doc.supplier_city or \"\" }}{% if doc.supplier_state %}, {{ doc.supplier_state }}{% endif %}\n                {% if doc.supplier_postal_code %}, {{ doc.supplier_postal_code }}{% endif %}<br>\n                Tel: {{doc.suplier_mobile or \"\"}}\n            </div>\n        </div>\n        <div class=\"top-band-right\">\n            <div>\n                <div class=\"inv-no\">{{ doc.name }}</div>\n                <div class=\"inv-meta\">{{ doc.get_formatted(\"posting_date\") }}</div>\n            </div>\n            {% if doc.validation_url %}\n            <div class=\"qr-wrap\">\n                {% set inv_types = {\"01\":\"Invoice\",\"02\":\"Credit Note\",\"03\":\"Debit Note\",\"04\":\"Refund Note\",\"11\":\"Self-billed\"} %}\n                <span class=\"inv-type-badge\" style=\"background:rgba(255,255,255,0.9); font-size:7px; color:#000; padding:2px 5px; border-radius:2px; margin-bottom:4px; display:block; text-align:center;\">{{ inv_types.get(doc.e_invoice_type_code|string, \"Invoice\") }} v1.1</span>\n                <img src=\"{{ doc.validation_url }}\">\n            </div>\n            {% endif %}\n        </div>\n    </div>\n\n    <!-- UUID -->\n    <div class=\"uuid-strip\">\n        <span class=\"uuid-label\">UUID</span>\n        <span class=\"uuid-value\">{{ doc.uuid or \"N/A\" }}</span>\n    </div>\n\n    <!-- PARTIES -->\n    <div class=\"parties\">\n        <div class=\"party-card\">\n            <div class=\"card-label\">Supplier</div>\n            <div class=\"card-name\">{{ doc.company }}</div>\n            <div style=\"font-size:10.5px\">\n                <strong>Tax Identification Number (TIN):</strong> {{ doc.supplier_tin or \"NA\" }}<br>\n                <strong>ID Type/Number: BRN/</strong> {{ doc.supplier_brn or \"NA\" }}<br>\n                <strong>MSIC:</strong> {{ doc.msic_codes or \"NA\" }}<br>\n                <strong>SST Registration Number:</strong> {{ \"NA\"}}<br>\n                <strong>Tourism Tax Reg No:</strong> {{ doc.tourism_tax_registration or \"NA\"}}<br>\n                <strong>Email:</strong> {{ doc.supplier_email_address or \"NA\"}}<br>\n                <strong>Business Activity:</strong> {{\"WHOLESALE OF HOUSEHOLD FORNITURE\"}}<br>\n                \n\n                \n            </div>\n        </div>\n        <div class=\"party-card\">\n            <div class=\"card-label\">Buyer</div>\n            <div class=\"card-name\">{{ doc.customer_name or \"General Public\" }}</div>\n            <div style=\"font-size:10.5px\">\n                <strong>TIN:</strong> {{ doc.customer_tin or \"\u2014\" }}\n            </div>\n        </div>\n    </div>\n\n    <!-- TABLE -->\n    <div class=\"section-heading\">Invoice Line Items</div>\n    \n    {% set tax_map = {\n        \"01\": \"Sales Tax\",\n        \"02\": \"Service Tax\",\n        \"03\": \"Tourism Tax\",\n        \"04\": \"High-Value Goods Tax\",\n        \"05\": \"Sales Tax (LVG)\",\n        \"06\": \"Not Applicable\",\n        \"E\":  \"Tax Exemption\"\n    } %}\n\n    <table class=\"inv-table\">\n        <thead>\n            <tr>\n                <th style=\"width:35px\">#</th>\n                <th>Customer / Invoice Reference</th>\n                <th style=\"width:75px\">Item Code</th>\n                <th style=\"width:120px\">Tax Category</th>\n                <th style=\"width:90px\">Total</th>\n                <th style=\"width:85px\">Tax</th>\n                <th style=\"width:85px\">Additional</th>\n            </tr>\n        </thead>\n        <tbody>\n            {% for row in doc.invoices or [] %}\n            <tr>\n                <td style=\"font-family:'JetBrains Mono'; font-size:10px;\">{{ loop.index }}</td>\n                <td>\n                    <div class=\"item-name\">{{ row.original_invoice}}</div>\n                    <!--<div class=\"item-ref\">{{ row.original_invoice or \"\" }}</div>-->\n                </td>\n                <td>004</td>\n                <td>\n                    {% if row.tax_catagory %}\n                        <span class=\"badge\">{{ tax_map.get(row.tax_catagory|string, row.tax_catagory) }}</span>\n                    {% endif %}\n                </td>\n                <td class=\"num\">{{ row.total or \"0.00\" }}</td>\n                <td class=\"num\">{{ row.total_taxes or \"0.00\" }}</td>\n                <td class=\"num\">{{ row.total_additional or \"0.00\" }}</td>\n            </tr>\n            {% endfor %}\n        </tbody>\n        <tfoot>\n            <tr>\n                <td colspan=\"4\" style=\"text-transform:uppercase; font-size:9px;\">Total Base Amount</td>\n                <td class=\"num\" colspan=\"3\">{{ doc.get_formatted(\"total\") or \"RM 0.00\" }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"4\" style=\"text-transform:uppercase; font-size:9px;\">Total Tax Amount</td>\n                <td class=\"num\" colspan=\"3\">{{ doc.get_formatted(\"total_tax_and_charges\") if doc.total_tax_and_charges else \"RM 0.00\" }}</td>\n            </tr>\n            <tr>\n                <td colspan=\"4\" style=\"text-transform:uppercase; font-size:9px;\">Total Additional Amount</td>\n                <td class=\"num\" colspan=\"3\">{{ doc.get_formatted(\"total_charge\") if doc.total_charge else \"RM 0.00\" }}</td>\n            </tr>\n        </tfoot>\n    </table>\n\n    <!-- TOTAL -->\n    <div class=\"total-container\">\n        <div class=\"grand-total-box\">\n            <div style=\"font-size:9px; text-transform:uppercase; font-weight:700;\">Total Amount Due</div>\n            <div class=\"gt-value\">{{ doc.get_formatted(\"grand_total\") }}</div>\n            <div style=\"font-size:10px; color:#cbd5e0;\">{{ doc.currency or \"MYR\" }} \u2022 Tax Inclusive</div>\n        </div>\n    </div>\n\n    <!-- FOOTER -->\n    <div style=\"margin-top: 40px; padding-top: 15px; border-top: 2px solid #1a202c; display: flex; justify-content: space-between; font-size: 9px; color: #4a5568; font-weight:600;\">\n        <span>{{ doc.company }}</span>\n        <span style=\"font-family:'JetBrains Mono'\">\n            Consolidated E-Invoice | Generated: {{ frappe.utils.now_datetime().strftime('%d-%m-%Y %H:%M') }}\n        </span>\n    </div>\n</div>\n\n</body>\n</html>",
