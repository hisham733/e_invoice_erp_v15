 "creation": "2026-02-05 17:16:53.296001",
 "css": "/* Force content inside paper boundaries */\n.print-format {\n    font-family: 'Helvetica Neue', Arial, sans-serif;\n    font-size: 11px;\n    padding: 20px;\n    color: #333;\n    width: 100%;\n    max-width: 100%;\n    box-sizing: border-box;\n    position: relative;\n    margin: 0 auto;\n}\n\n/* Fix row overflow */\n.row {\n    margin-left: 0 !important;\n    margin-right: 0 !important;\n}\n\n/* Fix columns */\n.col-xs-4, .col-xs-5, .col-xs-6, .col-xs-7, .col-xs-8 {\n    padding-left: 5px !important;\n    padding-right: 5px !important;\n    box-sizing: border-box !important;\n}\n\n.qr-status-container {\n    display: flex !important;\n    flex-direction: column !important;\n    align-items: flex-end !important;\n}\n\n.invoice-type-label {\n    margin-bottom: 6px;\n    text-align: center;\n}\n\n.qr-code {\n    width: 110px !important;\n    height: 110px !important;\n    margin-bottom: 8px;\n    display: block !important;\n    border: 1px solid #eee;\n}\n\n.qr-placeholder {\n    width: 110px;\n    height: 110px;\n    border: 1px dashed #ccc;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    text-align: center;\n    font-size: 8px;\n    color: #999;\n    margin-bottom: 8px;\n}\n\n.company-name {\n    color: #1a5a96;\n    font-weight: bold;\n    font-size: 16px;\n    margin: 0;\n}\n\n.status-badge {\n    padding: 4px 12px;\n    font-weight: bold;\n    font-size: 10px;\n    border-radius: 4px;\n    border: 1px solid #ddd;\n    text-align: center;\n    min-width: 110px;\n}\n\n.status-valid {\n    background-color: #e8f5e9 !important;\n    color: #2e7d32 !important;\n    border-color: #2e7d32 !important;\n}\n\n.header-line {\n    border-top: 2px solid #444;\n    margin: 15px 0;\n}\n\n.uuid-text {\n    font-size: 9px;\n    color: #777;\n    word-break: break-all;\n    display: block;\n    margin-top: 5px;\n}\n\n.item-table {\n    width: 100% !important;\n    table-layout: fixed;\n}\n\n.item-table thead th {\n    background-color: #f8f9fa !important;\n    border: 1px solid #ddd !important;\n}\n\n.total-table {\n    width: 100% !important;\n}\n\n.grand-total-row {\n    font-size: 13px;\n    background-color: #f1f1f1 !important;\n}\n\n.text-right {\n    text-align: right;\n}\n\n@page {\n    margin: 10mm;\n    size: A4;\n}\n\n@media print {\n    .print-format {\n        padding: 0;\n        width: 100%;\n    }\n\n    .qr-code {\n        image-rendering: -webkit-optimize-contrast;\n        -webkit-print-color-adjust: exact;\n    }\n}",
 "custom_format": 1,
 "default_print_language": "en",
